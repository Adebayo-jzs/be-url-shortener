generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model UrlMapping {
  short_code  String    @id @db.VarChar(255)
  long_url    String
  created_at  DateTime? @default(now()) @db.Timestamptz()
  expiry_date DateTime? @db.Timestamptz()
  click_count Int?      @default(0)

  @@index([expiry_date], name: "idx_url_mappings_expiry_date")
  @@map("url_mappings")
}
